# Copiá este archivo a backend/.env y completá lo que necesites.
# Todas las variables llevan el prefijo PBI_.

# Fuente de datos para LECTURAS (workspaces / datasets / tablas):
#   seed    -> datos de ejemplo, NO requiere credenciales (default, ideal para probar).
#   powerbi -> Power BI REST API real (usa las credenciales de abajo).
# Los schedules SIEMPRE se guardan localmente (PBI_DB_PATH), en cualquier modo.
PBI_DATA_SOURCE=seed

# --- Credenciales del service principal de Azure AD (solo si PBI_DATA_SOURCE=powerbi) ---
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=

# Scope del token de Power BI (normalmente no se toca).
PBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
# Base de la REST API (override para clouds soberanos, p. ej. .cn / .us).
PBI_API_BASE=https://api.powerbi.com/v1.0/myorg
# Autoridad de Azure AD.
PBI_AUTHORITY=https://login.microsoftonline.com

# CORS: orígenes del frontend permitidos, separados por coma. "*" = todos.
# En producción detrás de nginx (mismo origen) podés dejar "*" o el dominio real.
PBI_CORS_ORIGINS=*

# Archivo de persistencia de los schedules (relativo al cwd o ruta absoluta).
PBI_DB_PATH=schedules.json
