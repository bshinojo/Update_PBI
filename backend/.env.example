# Copiá este archivo a backend/.env y completá las credenciales.
# Todas las variables llevan el prefijo PBI_.

# --- Credenciales del service principal de Azure AD (OBLIGATORIAS) ---
# La herramienta lee (workspaces/datasets/tablas) y dispara los refreshes contra
# Power BI real. Sin estas credenciales el backend no arranca.
# OJO: PBI_CLIENT_SECRET es el *Value* del secret, no el Secret ID.
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=

# Scope del token de Power BI (normalmente no se toca).
PBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
# Base de la REST API (override para clouds soberanos, p. ej. .cn / .us).
PBI_API_BASE=https://api.powerbi.com/v1.0/myorg
# Autoridad de Azure AD.
PBI_AUTHORITY=https://login.microsoftonline.com

# CORS: orígenes del frontend permitidos, separados por coma. "*" = todos.
# En producción detrás de nginx (mismo origen) podés dejar "*" o el dominio real.
PBI_CORS_ORIGINS=*

# Archivo de persistencia de los schedules (relativo al cwd o ruta absoluta).
PBI_DB_PATH=schedules.json

# Historial de corridas (audit log, JSON Lines append-only: una línea por refresh
# terminado). Vacío ("") lo desactiva.
PBI_RUNS_LOG_PATH=runs.jsonl

# Nivel de log de la app (DEBUG/INFO/WARNING/ERROR). Los loggers "pbi.*" registran
# lo que hace el scheduler, el executor y el cliente de Power BI.
PBI_LOG_LEVEL=INFO

# --- Scheduler (worker que dispara los refreshes) ---
# Apagar el worker (p. ej. si querés correr solo la API): 0.
PBI_SCHEDULER_ENABLED=true
# Cada cuántos segundos revisa schedules vencidos y pollea refreshes en vuelo.
PBI_SCHEDULER_TICK_SECONDS=30
# Offset de la zona horaria de los horarios (ART = UTC-3).
PBI_TZ_OFFSET_HOURS=-3
# Tope para un refresh "en curso": pasado este tiempo se marca Failed (anti-colgados).
PBI_REFRESH_POLL_TIMEOUT_MIN=120

# --- Scanner API (fallback para listar tablas de modelos con RLS) ---
# Los modelos con seguridad a nivel de fila (RLS) rechazan las consultas DAX del service
# principal (401), así que sus tablas no se pueden listar vía executeQueries. Como fallback
# se usa la Scanner API (admin metadata), que lee el esquema sin ejecutar DAX. Requiere que
# el tenant permita al SP usar las read-only admin APIs ("Allow service principals to use
# read-only Power BI admin APIs"). Poner 0 para desactivar el fallback.
PBI_SCANNER_ENABLED=true
# Minutos que se cachea el resultado del scan (mapa dataset -> tablas) antes de re-escanear.
PBI_SCANNER_CACHE_TTL_MIN=10
# Tope de espera (segundos) para que un scan termine antes de rendirse.
PBI_SCANNER_POLL_TIMEOUT_SEC=60
