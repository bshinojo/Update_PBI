# Modo del backend.
#  - 'mock' (default): datos inventados persistidos en localStorage, con delays simulados.
#  - 'http': backend real FastAPI (ya implementado, ver backend/). El HttpScheduleApi
#    usa baseUrl '/api'; en producción nginx hace proxy de /api/ -> backend (ver
#    nginx.example.conf). En dev, levantá el backend (backend/run.sh) y serví el front
#    detrás del mismo nginx, o ajustá el baseUrl en src/api/http/http-client.ts.
VITE_API_MODE=mock

# Poné VITE_MOCK_FAIL=1 para que el mock falle aleatoriamente y puedas
# ver los estados de error en cada nivel de navegación. Dejalo sin definir (o =0) normalmente.
# VITE_MOCK_FAIL=0
