# Modo del backend.
#  - 'mock' (default): datos inventados persistidos en localStorage, con delays simulados.
#  - 'http': backend real (FastAPI). Todavía no implementado: el cliente HTTP es un stub.
VITE_API_MODE=mock

# Poné VITE_MOCK_FAIL=1 para que el mock falle aleatoriamente y puedas
# ver los estados de error en cada nivel de navegación. Dejalo sin definir (o =0) normalmente.
# VITE_MOCK_FAIL=0
